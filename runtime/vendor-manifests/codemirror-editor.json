{
  "id": "codemirror-editor",
  "packageName": "codemirror",
  "sourceEntry": "extensions/viewers/editor/vendor/codemirror-entry.ts",
  "outputFile": "extensions/viewers/editor/vendor/codemirror.js",
  "metadataFile": "extensions/viewers/editor/vendor/codemirror.meta.json",
  "buildCommand": [
    "bun",
    "build",
    "$SOURCE_ENTRY",
    "--target=browser",
    "--format=esm",
    "--minify",
    "--outfile",
    "$OUTPUT_FILE"
  ]
}
